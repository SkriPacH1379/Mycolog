<Window x:Class="Mycolog.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mycolog — Дневник грибного культиватора" Height="720" Width="1180"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <GroupBox Header="Новая / Редактируемая культура" Grid.Row="0">
            <Grid Margin="10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="220"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Вид гриба -->
                <TextBlock Text="Вид гриба:" Grid.Row="0" Margin="4,8"/>
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                    <ComboBox x:Name="cmbSpecies" Width="170" IsEditable="True" Margin="4"/>
                    <Button Content="..." Width="28" Height="28" Padding="0" Click="ManageSpecies_Click" ToolTip="Управление видами" Foreground="Wheat"/>
                </StackPanel>

                <!-- Штамм -->
                <TextBlock Text="Штамм:" Grid.Row="0" Grid.Column="2" Margin="4,8"/>
                <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal">
                    <ComboBox x:Name="cmbStrain" Width="170" IsEditable="True" Margin="4"/>
                    <Button Content="..." Width="28" Height="28" Padding="0" Click="ManageStrains_Click" ToolTip="Управление штаммами"/>
                </StackPanel>

                <!-- Дата начала -->
                <TextBlock Text="Дата начала:" Grid.Row="1" Margin="4,8"/>
                <DatePicker x:Name="dpStartDate" Grid.Row="1" Grid.Column="1" Margin="4"/>

                <!-- Субстрат -->
                <TextBlock Text="Субстрат:" Grid.Row="1" Grid.Column="2" Margin="4,8"/>
                <StackPanel Grid.Row="1" Grid.Column="3" Orientation="Horizontal">
                    <ComboBox x:Name="cmbSubstrate" Width="170" IsEditable="True" Margin="4"/>
                    <Button Content="..." Width="28" Height="28" Padding="0" Click="ManageSubstrates_Click" ToolTip="Управление субстратами"/>
                </StackPanel>

                <!-- Ёмкость -->
                <TextBlock Text="Ёмкость:" Grid.Row="2" Margin="4,8"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal">
                    <ComboBox x:Name="cmbContainer" Width="170" IsEditable="True" Margin="4"/>
                    <Button Content="..." Width="28" Height="28" Padding="0" Click="ManageContainers_Click" ToolTip="Управление ёмкостями"/>
                </StackPanel>

                <!-- Стадия -->
                <TextBlock Text="Стадия:" Grid.Row="2" Grid.Column="2" Margin="4,8"/>
                <StackPanel Grid.Row="2" Grid.Column="3" Orientation="Horizontal">
                    <ComboBox x:Name="cmbStage" Width="170" Margin="4"/>
                    <Button Content="..." Width="28" Height="28" Padding="0" Click="ManageStages_Click" ToolTip="Управление стадиями"/>
                </StackPanel>

                <!-- Температура и Влажность -->
                <TextBlock Text="Температура (°C):" Grid.Row="3" Margin="4,8"/>
                <TextBox x:Name="txtTemp" Grid.Row="3" Grid.Column="1" Margin="4"/>

                <TextBlock Text="Влажность (%):" Grid.Row="3" Grid.Column="2" Margin="4,8"/>
                <TextBox x:Name="txtHumidity" Grid.Row="3" Grid.Column="3" Margin="4"/>

                <!-- Вес урожая -->
                <TextBlock Text="Вес урожая (г):" Grid.Row="4" Margin="4,8"/>
                <TextBox x:Name="txtHarvestWeight" Grid.Row="4" Grid.Column="1" Margin="4"/>

                <!-- Заметки -->
                <TextBlock Text="Заметки:" Grid.Row="5" Margin="4,8"/>
                <TextBox x:Name="txtNotes" Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="3" 
                         Height="80" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" Margin="4"/>

                <!-- Кнопка сохранить -->
                <Button Content="Сохранить культуру" Click="SaveButton_Click" 
                        Grid.Row="6" Grid.Column="3" FontSize="14" Padding="0" Margin="4" Height="35"/>
            </Grid>
        </GroupBox>

        <DataGrid x:Name="dgCultures" Grid.Row="1" AutoGenerateColumns="False" IsReadOnly="True"
                  SelectionChanged="dgCultures_SelectionChanged" Margin="0,10,0,0">
            
            <DataGrid.Columns>
                <DataGridTextColumn Header="Вид" Binding="{Binding Species}" Width="130"/>
                <DataGridTextColumn Header="Штамм" Binding="{Binding Strain}" Width="110"/>
                <DataGridTextColumn Header="Начало" Binding="{Binding StartDate, StringFormat=dd.MM.yyyy}" Width="95"/>
                <DataGridTextColumn Header="Стадия" Binding="{Binding CurrentStage}" Width="120"/>
                <DataGridTextColumn Header="°C" Binding="{Binding Temperature}" Width="60"/>
                <DataGridTextColumn Header="% Вл." Binding="{Binding Humidity}" Width="70"/>
                <DataGridCheckBoxColumn Header="Собрано" Binding="{Binding IsHarvested}" Width="70"/>
                <DataGridTextColumn Header="Вес (г)" Binding="{Binding HarvestWeight}" Width="80"/>
                <DataGridTextColumn Header="Заметки" Binding="{Binding Notes}" Width="*" MinWidth="200"/>

                <DataGridTemplateColumn Header="Действия" Width="140">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <Button Style="{StaticResource DataGridActionButton}" Content="Изменить" Background="#2196F3" Foreground="White" Click="EditButton_Click"/>
                                <Button Style="{StaticResource DataGridActionButton}" Content="Удалить" Background="#f44336" Foreground="White" Click="DeleteButton_Click"/>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Window>